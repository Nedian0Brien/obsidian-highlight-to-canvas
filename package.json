{
  "name": "highlight-to-canvas",
  "version": "0.1.1",
  "description": "Turn PDF highlights into connected Obsidian Canvas nodes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -noEmit -skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "pdf",
    "canvas",
    "highlight"
  ],
  "author": "Minjae Park",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.5",
    "obsidian": "^1.5.12",
    "tslib": "^2.6.3",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.4.168"
  }
}
